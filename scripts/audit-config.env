# ─── Audit Configuration ──────────────────────────────────
# Environment variables for the AI agent audit system.

# App URL to audit
AUDIT_BASE_URL=http://localhost:3001

# GitHub repository (for issue filing)
AUDIT_GITHUB_REPO=

# Performance thresholds
AUDIT_MAX_LCP_MS=4000
AUDIT_MAX_CLS=0.25
AUDIT_MAX_API_RESPONSE_MS=5000

# Issue filing
AUDIT_ISSUE_LABEL=ai-audit
AUDIT_AUTO_FILE_ISSUES=true

# Report retention (days)
AUDIT_REPORT_RETENTION_DAYS=30
